    photo watermark wide.png bottom-right 220 60 12  # Bigger region when needed
    photo postcard vacation.png     # Print-ready postcard

WATERMARK POSITIONS:
    bottom-right (default), bottom-left, top-right, top-left, bottom-center
""")


if __name__ == "__main__":
    sys.exit(main() or 0)
